#!/usr/bin/env python3
"""Extract the last N conversational messages from a Claude Code session.

Usage:
  session-tail e78cc80e                    # last 3 messages from session
  session-tail e78cc80e --last=5           # last 5 messages
  session-tail e78cc80e --json             # output as JSON
  session-tail e78cc80e --last=1 --role=human  # last user message only

Resolves 8-char prefixes to full session IDs. Searches all project dirs.

Also available as part of the /sessions skill inside Claude Code.
"""

import argparse
import json
import os
import sys
import datetime
import textwrap

PROJECTS_DIR = os.path.expanduser("~/.claude/projects")
HOME = os.path.expanduser("~")


def decode_project_dir(dirname: str) -> str:
    """Convert encoded project dir name back to a filesystem path."""
    raw = dirname.lstrip("-")
    parts = raw.split("-")
    resolved = "/"
    i = 0
    while i < len(parts):
        candidate = os.path.join(resolved, parts[i])
        if os.path.isdir(candidate):
            resolved = candidate
            i += 1
        else:
            found = False
            for j in range(len(parts), i, -1):
                hyphenated = "-".join(parts[i:j])
                candidate = os.path.join(resolved, hyphenated)
                if os.path.isdir(candidate):
                    resolved = candidate
                    i = j
                    found = True
                    break
            if not found:
                resolved = os.path.join(resolved, "-".join(parts[i:]))
                break
    return resolved


def friendly_path(path: str) -> str:
    if path.startswith(HOME):
        return "~" + path[len(HOME):]
    return path


def find_session_file(session_prefix: str) -> tuple[str, str, str] | None:
    """Find a session JSONL file by ID prefix. Returns (jsonl_path, session_id, display_path)."""
    if not os.path.isdir(PROJECTS_DIR):
        return None

    for proj_dir_name in os.listdir(PROJECTS_DIR):
        proj_path = os.path.join(PROJECTS_DIR, proj_dir_name)
        if not os.path.isdir(proj_path):
            continue
        for f in os.listdir(proj_path):
            if not f.endswith(".jsonl"):
                continue
            session_id = f[:-6]
            if session_id.startswith(session_prefix) or session_prefix == session_id:
                real_path = decode_project_dir(proj_dir_name)
                return (
                    os.path.join(proj_path, f),
                    session_id,
                    friendly_path(real_path),
                )
    return None


def extract_text(content) -> str:
    """Extract plain text from message content (string or content blocks)."""
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for block in content:
            if isinstance(block, dict):
                if block.get("type") == "text":
                    parts.append(block.get("text", ""))
                elif block.get("type") == "tool_use":
                    tool = block.get("name", "unknown")
                    parts.append(f"[tool_use: {tool}]")
                elif block.get("type") == "tool_result":
                    parts.append("[tool_result]")
        return "\n".join(parts)
    return str(content)


def get_tail_messages(jsonl_path: str, last: int, role_filter: str | None = None) -> list[dict]:
    """Extract the last N human/assistant messages from a session."""
    messages = []
    try:
        with open(jsonl_path, "r") as f:
            for line in f:
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue

                msg_type = obj.get("type")
                if msg_type not in ("human", "user", "assistant"):
                    continue

                role = "human" if msg_type in ("human", "user") else "assistant"
                if role_filter and role != role_filter:
                    continue

                msg = obj.get("message", {})
                content = msg.get("content", "")
                text = extract_text(content)

                if not text.strip():
                    continue

                messages.append({
                    "role": role,
                    "text": text,
                    "timestamp": obj.get("timestamp", ""),
                })
    except Exception as e:
        print(f"Error reading session: {e}", file=sys.stderr)
        return []

    return messages[-last:]


def main():
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("session_id", help="Session ID or 8-char prefix")
    parser.add_argument("--last", type=int, default=3, help="Number of messages to show (default: 3)")
    parser.add_argument("--role", choices=["human", "assistant"], default=None, help="Filter to one role")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument("--max-length", type=int, default=500, help="Max text length per message (default: 500)")
    args = parser.parse_args()

    result = find_session_file(args.session_id)
    if not result:
        print(f"No session found matching '{args.session_id}'", file=sys.stderr)
        sys.exit(1)

    jsonl_path, full_id, display_path = result
    messages = get_tail_messages(jsonl_path, args.last, args.role)

    if args.json:
        out = {
            "session_id": full_id,
            "path": display_path,
            "messages": [],
        }
        for m in messages:
            text = m["text"]
            if len(text) > args.max_length:
                text = text[:args.max_length] + "..."
            out["messages"].append({
                "role": m["role"],
                "text": text,
                "timestamp": m["timestamp"],
            })
        print(json.dumps(out, indent=2))
        return

    print(f"Session: {full_id[:8]}  ({display_path})")
    print(f"Last {len(messages)} message(s):")
    print()
    for m in messages:
        role_label = "USER" if m["role"] == "human" else "ASST"
        text = m["text"]
        if len(text) > args.max_length:
            text = text[:args.max_length] + "..."
        # Indent continuation lines
        lines = text.split("\n")
        print(f"  [{role_label}] {lines[0]}")
        for line in lines[1:]:
            print(f"         {line}")
        print()


if __name__ == "__main__":
    main()
