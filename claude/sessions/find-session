#!/usr/bin/env python3
"""Search recent Claude Code session content for keywords or patterns.

Usage:
  find-session "deploy"                        # search 10 most recent sessions
  find-session "deploy" "error" --most-recent=20  # OR: either term matches
  find-session "deploy" "cloud run" --all      # AND: both terms must match
  find-session "deploy" --json                 # output matches as JSON
  find-session "skill-review" --name           # match against custom session name

Multiple patterns are OR by default (like grep -e). Use --all for AND.

Unlike list-sessions --summary-contains (which only searches the first message),
this searches the full session JSONL content, finding topics discussed mid-session
or in assistant responses.

Use --name to search only custom session titles (set via /rename) instead of
full content. This is useful for finding sessions by their assigned name.

Also available as /sessions skill inside Claude Code.
"""

import argparse
import json
import os
import re
import sys
import datetime

PROJECTS_DIR = os.path.expanduser("~/.claude/projects")
HOME = os.path.expanduser("~")
DEFAULT_MOST_RECENT = 10


def is_subagent_session(real_path: str) -> bool:
    """Check if a session path looks like a subagent or test session."""
    return not real_path.startswith(HOME)


def decode_project_dir(dirname: str) -> str:
    """Convert encoded project dir name back to a filesystem path."""
    raw = dirname.lstrip("-")
    parts = raw.split("-")
    resolved = "/"
    i = 0
    while i < len(parts):
        candidate = os.path.join(resolved, parts[i])
        if os.path.isdir(candidate):
            resolved = candidate
            i += 1
        else:
            found = False
            for j in range(len(parts), i, -1):
                hyphenated = "-".join(parts[i:j])
                candidate = os.path.join(resolved, hyphenated)
                if os.path.isdir(candidate):
                    resolved = candidate
                    i = j
                    found = True
                    break
            if not found:
                resolved = os.path.join(resolved, "-".join(parts[i:]))
                break
    return resolved


def friendly_path(path: str) -> str:
    if path.startswith(HOME):
        return "~" + path[len(HOME):]
    return path


def format_age(mtime: float) -> str:
    now = datetime.datetime.now()
    mod_dt = datetime.datetime.fromtimestamp(mtime)
    delta = now - mod_dt
    if delta.total_seconds() < 60:
        return "just now"
    elif delta.total_seconds() < 3600:
        return f"{int(delta.total_seconds() // 60)}m ago"
    elif delta.total_seconds() < 86400:
        return f"{int(delta.total_seconds() // 3600)}h ago"
    elif delta.days == 1:
        return "yesterday"
    else:
        return f"{delta.days}d ago"


def get_first_user_message(jsonl_path: str) -> tuple[str, str | None]:
    """Extract first user message and custom title."""
    summary = ""
    name = None
    try:
        with open(jsonl_path, "r") as f:
            for line in f:
                try:
                    obj = json.loads(line)
                    if not summary and obj.get("type") == "user" and obj.get("message", {}).get("role") == "user":
                        content = obj["message"]["content"]
                        if isinstance(content, str):
                            summary = content.replace("\n", " ").strip()
                        elif isinstance(content, list):
                            for part in content:
                                if isinstance(part, dict) and part.get("type") == "text":
                                    summary = part["text"].replace("\n", " ").strip()
                                    break
                    elif obj.get("type") == "custom-title":
                        name = obj.get("customTitle")
                except json.JSONDecodeError:
                    continue
    except Exception:
        pass
    return summary, name


def collect_recent_session_files(most_recent: int, include_subagents: bool = False) -> list[dict]:
    """Collect the N most recent top-level session JSONL files."""
    if not os.path.isdir(PROJECTS_DIR):
        return []

    all_files = []
    for proj_dir_name in os.listdir(PROJECTS_DIR):
        proj_path = os.path.join(PROJECTS_DIR, proj_dir_name)
        if not os.path.isdir(proj_path):
            continue

        real_path = decode_project_dir(proj_dir_name)

        if not include_subagents and is_subagent_session(real_path):
            continue

        display_path = friendly_path(real_path)

        for f in os.listdir(proj_path):
            if not f.endswith(".jsonl"):
                continue
            jsonl_path = os.path.join(proj_path, f)
            session_id = f[:-6]
            mtime = os.path.getmtime(jsonl_path)
            all_files.append({
                "jsonl_path": jsonl_path,
                "session_id": session_id,
                "path": display_path,
                "modified": mtime,
            })

    all_files.sort(key=lambda x: x["modified"], reverse=True)
    return all_files[:most_recent]


def search_session(jsonl_path: str, pattern: re.Pattern, max_snippets: int = 3) -> list[str]:
    """Search a session JSONL for lines matching pattern. Returns snippet strings."""
    snippets = []
    try:
        with open(jsonl_path, "r") as f:
            for line in f:
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue

                # Extract searchable text from the message
                texts = []
                msg = obj.get("message", {})
                content = msg.get("content", "")
                if isinstance(content, str):
                    texts.append(content)
                elif isinstance(content, list):
                    for part in content:
                        if isinstance(part, dict):
                            if part.get("type") == "text":
                                texts.append(part.get("text", ""))
                            elif part.get("type") == "tool_use":
                                # Search tool input for keyword (e.g. agent prompts)
                                inp = part.get("input", {})
                                if isinstance(inp, dict):
                                    texts.append(inp.get("prompt", ""))
                                    texts.append(inp.get("command", ""))

                # Also check tool_result content
                if obj.get("type") == "tool_result":
                    result_content = obj.get("content", "")
                    if isinstance(result_content, str):
                        texts.append(result_content)

                for text in texts:
                    if not text:
                        continue
                    match = pattern.search(text)
                    if match:
                        # Extract a snippet around the match
                        start = max(0, match.start() - 60)
                        end = min(len(text), match.end() + 60)
                        snippet = text[start:end].replace("\n", " ").strip()
                        if start > 0:
                            snippet = "..." + snippet
                        if end < len(text):
                            snippet = snippet + "..."
                        snippets.append(snippet)
                        if len(snippets) >= max_snippets:
                            return snippets
    except Exception:
        pass
    return snippets


def main():
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("patterns", nargs="+", help="Search terms or regex patterns (OR by default)")
    parser.add_argument(
        "--all", action="store_true", dest="match_all",
        help="Require ALL patterns to match (default: any pattern matches)",
    )
    parser.add_argument(
        "--most-recent", type=int, default=DEFAULT_MOST_RECENT,
        help=f"Number of most recent sessions to search (default: {DEFAULT_MOST_RECENT})",
    )
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument(
        "--max-snippets", type=int, default=3,
        help="Max matching snippets to show per session (default: 3)",
    )
    parser.add_argument(
        "--include-subagents", action="store_true",
        help="Include subagent and test sessions from temp directories (hidden by default)",
    )
    parser.add_argument(
        "--include-archived", action="store_true",
        help="Include ARCHIVE: sessions (hidden by default)",
    )
    parser.add_argument(
        "--name", action="store_true",
        help="Search custom session names (set via /rename) instead of full content",
    )
    args = parser.parse_args()

    compiled = []
    for p in args.patterns:
        try:
            compiled.append(re.compile(p, re.IGNORECASE))
        except re.error as e:
            print(f"Invalid pattern '{p}': {e}", file=sys.stderr)
            sys.exit(1)

    sessions = collect_recent_session_files(args.most_recent, include_subagents=args.include_subagents)
    if not sessions:
        print("No sessions found.")
        return

    matches = []
    archived_skipped = 0
    for s in sessions:
        summary, name = get_first_user_message(s["jsonl_path"])

        # Skip archived sessions unless explicitly requested
        if not args.include_archived and name and re.match(r'^\s*archive\s*:', name, re.IGNORECASE):
            archived_skipped += 1
            continue

        if args.name:
            # --name mode: match patterns against custom session name only
            if not name:
                continue
            matched_patterns = set()
            for i, pat in enumerate(compiled):
                if pat.search(name):
                    matched_patterns.add(i)
            if args.match_all and len(matched_patterns) < len(compiled):
                continue
            if not args.match_all and not matched_patterns:
                continue
            unique_snippets = []
        else:
            # Default mode: search full session content
            all_snippets = []
            matched_patterns = set()
            for i, pat in enumerate(compiled):
                snippets = search_session(s["jsonl_path"], pat, max_snippets=args.max_snippets)
                if snippets:
                    matched_patterns.add(i)
                    all_snippets.extend(snippets)

            if args.match_all and len(matched_patterns) < len(compiled):
                continue
            if not args.match_all and not matched_patterns:
                continue

            # Deduplicate snippets while preserving order
            seen = set()
            unique_snippets = []
            for snip in all_snippets:
                if snip not in seen:
                    seen.add(snip)
                    unique_snippets.append(snip)

        matches.append({
            "session_id": s["session_id"],
            "path": s["path"],
            "age": format_age(s["modified"]),
            "modified": s["modified"],
            "summary": summary[:120],
            "name": name,
            "snippets": unique_snippets[:args.max_snippets],
        })

    if args.json:
        print(json.dumps(matches, indent=2))
        return

    mode = "ALL of" if args.match_all else "any of"
    label = ", ".join(f"'{p}'" for p in args.patterns)
    if len(args.patterns) == 1:
        label = f"'{args.patterns[0]}'"
        mode_desc = label
    else:
        mode_desc = f"{mode} [{label}]"

    if not matches:
        print(f"No matches for {mode_desc} in the {args.most_recent} most recent sessions.")
        return

    searched_note = f"searched {len(sessions)}"
    if archived_skipped:
        searched_note += f", {archived_skipped} archived skipped"
    print(f"Found {mode_desc} in {len(matches)} session(s) ({searched_note}):\n")
    for i, m in enumerate(matches, 1):
        display = m["name"] if m.get("name") else m["summary"]
        if m.get("name"):
            display = f"[{display}]"
        if len(display) > 90:
            display = display[:87] + "..."
        sid_short = m["session_id"][:8]
        print(f"  {i}. {m['age']:<12} {m['path']}")
        print(f"     {display}")
        print(f"     Resume: cd {m['path']} && claude -r {sid_short}")
        for snippet in m["snippets"]:
            if len(snippet) > 120:
                snippet = snippet[:117] + "..."
            print(f"       > {snippet}")
        print()


if __name__ == "__main__":
    main()
